# 部署环境
DEPLOY_ENV=prod

# 项目配置
PROJECT_NAME = FastapiAdmin

# 默认数据库配置
DATABASE_TYPE = postgres
DATABASE_NAME = "fastapiadmin"
DATABASE_PORT = 5432            # MySQL默认端口3306 PostgreSQL默认端口5432
DATABASE_USER = "postgres"    # PostgreSQL 默认用户是 postgres
DATABASE_PASSWORD = "you_db_password"


# MYSQL_DATABASE = "fastapiadmin"
# MYSQL_PORT = 5432               # mysql 默认端口3306
# MYSQL_USER = "fastapiadmin"     # mysql 默认用户是 fastapiadmin
# MYSQL_PASSWORD = "you_db_password"
# MYSQL_ROOT_PASSWORD = "you_db_password"


# POSTGRES_DATABASE = "fastapiadmin"
# POSTGRES_PORT = 5432            # MySQL默认端口3306 PostgreSQL默认端口5432
# POSTGRES_USER = "postgres"    # PostgreSQL 默认用户是 postgres
# POSTGRES_PASSWORD = "you_db_password"
# POSTGRES_ROOT_PASSWORD = "you_db_password"


# Redis配置
REDIS_PORT = 6379
# 为空时使用 Redis default 用户；非空时 docker-compose 会创建对应 ACL 用户。
REDIS_USER = ""
REDIS_PASSWORD = "you_redis_password"
  
# 后端配置
BACKEND_PORT = 8001
  
# Nginx配置
HTTP_PORT = 80
HTTPS_PORT = 443

# 日志配置
LOGGER_LEVEL = "INFO"

# 大模型配置
OPENAI_BASE_URL = "https://api.deepseek.com"
OPENAI_API_KEY = "your_api_key"
OPENAI_MODEL = "deepseek-chat"

# 医专医院 LIS（检验科全部收样后上传；与旧 PHP jsbb 一致）
YIZHUAN_LIS_UPLOAD_ENABLE = false
YIZHUAN_LIS_UPLOAD_URL = ""
YIZHUAN_LIS_HTTP_TIMEOUT = 30
